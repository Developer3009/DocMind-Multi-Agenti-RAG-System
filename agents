"""
RAG Agent — answers questions from uploaded PDF documents.
"""

from __future__ import annotations
from typing import Any
from langchain_ollama import ChatOllama
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.messages import HumanMessage


RAG_PROMPT = ChatPromptTemplate.from_template("""You are a precise document QA assistant.
Answer ONLY using the retrieved context below. If the answer isn't in the context,
say exactly: "The documents don't contain information about this."

Retrieved context:
{context}

Question: {question}

Provide a clear, accurate answer with specific details from the documents:""")


class RAGAgent:
    """Retrieves relevant chunks and answers from document context."""

    name = "rag_agent"
    description = "Answers questions from uploaded PDF documents"

    def __init__(self, model: str, base_url: str, retriever: Any | None = None):
        self.llm = ChatOllama(model=model, base_url=base_url, temperature=0.1, streaming=True)
        self.retriever = retriever

    def set_retriever(self, retriever: Any):
        self.retriever = retriever

    def _format_docs(self, docs) -> tuple[str, list[dict]]:
        context = "\n\n---\n\n".join(d.page_content for d in docs)
        sources = []
        seen = set()
        for d in docs:
            import os
            key = (d.metadata.get("source", ""), d.metadata.get("page", 0))
            if key not in seen:
                seen.add(key)
                sources.append({
                    "file": os.path.basename(d.metadata.get("source", "unknown")),
                    "page": d.metadata.get("page", "?"),
                    "snippet": d.page_content[:250] + "…",
                })
        return context, sources

    def run(self, query: str) -> tuple[str, list[dict]]:
        """Returns (answer_text, source_list)."""
        if not self.retriever:
            return "No documents indexed yet. Please upload PDFs first.", []

        docs = self.retriever.invoke(query)
        if not docs:
            return "No relevant document chunks found for this query.", []

        context, sources = self._format_docs(docs)
        chain = RAG_PROMPT | self.llm
        response = chain.invoke({"context": context, "question": query})
        return response.content, sources

    def stream(self, query: str):
        """Generator: yields (token, sources_or_None)."""
        if not self.retriever:
            yield "No documents indexed yet.", []
            return

        docs = self.retriever.invoke(query)
        context, sources = self._format_docs(docs) if docs else ("", [])

        chain = RAG_PROMPT | self.llm
        full_text = ""
        for chunk in chain.stream({"context": context, "question": query}):
            token = chunk.content if hasattr(chunk, "content") else str(chunk)
            full_text += token
            yield token, None

        yield "", sources





